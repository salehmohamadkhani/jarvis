# ============================================
# JARVIS - نمونه متغیرهای محیطی
# کپی کن: cp .env.example .env.local و مقادیر را پر کن
# ============================================

# دیتابیس PostgreSQL (مثلاً Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI (از https://platform.openai.com/api-keys)
OPENAI_API_KEY=
VITE_OPENAI_API_KEY=

# Gemini (در صورت استفاده)
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# آدرس بک‌اند برای فرانت (خالی = همان دامنه)
VITE_API_BASE_URL=
VITE_BACKEND_URL=

PORT=3001
