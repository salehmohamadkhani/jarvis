// server.js
import express from 'express';
import cors from 'cors';
import path from 'path';
import { fileURLToPath } from 'url';
import { Pool } from 'pg';

// ---------- تنظیمات عمومی ----------
const app = express();
const PORT = process.env.PORT || 3001;

app.use(cors());
app.use(express.json());

// ---------- اتصال به دیتابیس Neon ----------
// مطمئن شو متغیر DATABASE_URL در .env یا تنظیمات سرور ست شده
const pool = new Pool({
  connectionString: process.env.DATABASE_URL,
  ssl: { rejectUnauthorized: false },
});

async function dbHealthCheck() {
  const client = await pool.connect();
  try {
    await client.query('SELECT 1');
    return true;
  } finally {
    client.release();
  }
}

// ---------- API ها ----------

// Health check
app.get('/api/health', async (req, res) => {
  try {
    await dbHealthCheck();
    res.json({ ok: true, database: true });
  } catch (err) {
    console.error('DB health error:', err.message);
    res.status(500).json({ ok: false, database: false, error: 'Database connection failed' });
  }
});

// فعلاً APIهای اصلی رو خالی برمی‌گردونیم تا UI بالا بیاد
app.get('/api/projects', (req, res) => {
  res.json([]);
});

app.get('/api/tasks', (req, res) => {
  res.json([]);
});

app.get('/api/meetings', (req, res) => {
  res.json([]);
});

app.get('/api/collaborators', (req, res) => {
  res.json([]);
});
// Gemini API Proxy endpoint
app.post('/api/gemini-proxy', async (req, res) => {
  try {
    console.log('Gemini proxy called, body:', JSON.stringify(req.body).substring(0, 100));
    const apiKey = process.env.VITE_GEMINI_API_KEY;
    if (!apiKey) {
      return res.status(500).json({ error: 'GEMINI_API_KEY not configured' });
    }
    if (!req.body || !req.body.contents) {
      return res.status(400).json({ error: 'Invalid request body' });
    }
    const requestBody = req.body;
    const model = requestBody.model || 'models/gemini-2.0-flash';
    const geminiBody = { ...requestBody };
    delete geminiBody.model;
    const url = 'https://generativelanguage.googleapis.com/v1beta/' + model + ':generateContent?key=' + apiKey;
    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(geminiBody),
    });
    if (!response.ok) {
      const text = await response.text().catch(() => '');
      return res.status(response.status).json({ 
        error: 'Gemini API error: ' + response.status,
        details: text 
      });
    }
    const data = await response.json();
    res.json(data);
  } catch (error) {
    console.error('Gemini proxy error:', error);
    res.status(500).json({ error: error.message });
  }
});


// ---------- سرو کردن فرانت React از dist ----------

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const distPath = path.join(__dirname, 'dist');

app.use(express.static(distPath));

// هر آدرس دیگری -> index.html (برای React Router)
app.get('*', (req, res) => {
  res.sendFile(path.join(distPath, 'index.html'));
});

// ---------- استارت سرور ----------
app.listen(PORT, '0.0.0.0', () => {
  console.log(`Server listening on port ${PORT}`);
});
