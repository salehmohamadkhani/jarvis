// server.js
import express from 'express';
import cors from 'cors';
import path from 'path';
import { fileURLToPath } from 'url';
import { Pool } from 'pg';

// ---------- تنظیمات عمومی ----------
const app = express();
const PORT = process.env.PORT || 3001;

app.use(cors());
app.use(express.json());

// ---------- اتصال به دیتابیس Neon ----------
// مطمئن شو متغیر DATABASE_URL در .env یا تنظیمات سرور ست شده
const pool = new Pool({
  connectionString: process.env.DATABASE_URL,
  ssl: { rejectUnauthorized: false },
});

async function dbHealthCheck() {
  const client = await pool.connect();
  try {
    await client.query('SELECT 1');
    return true;
  } finally {
    client.release();
  }
}

// ---------- API ها ----------

// Health check
app.get('/api/health', async (req, res) => {
  try {
    await dbHealthCheck();
    res.json({ ok: true, database: true });
  } catch (err) {
    console.error('DB health error:', err.message);
    res.status(500).json({ ok: false, database: false, error: 'Database connection failed' });
  }
});

// فعلاً APIهای اصلی رو خالی برمی‌گردونیم تا UI بالا بیاد
app.get('/api/projects', (req, res) => {
  res.json([]);
});

app.get('/api/tasks', (req, res) => {
  res.json([]);
});

app.get('/api/meetings', (req, res) => {
  res.json([]);
});

app.get('/api/collaborators', (req, res) => {
  res.json([]);
});

// ---------- سرو کردن فرانت React از dist ----------

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const distPath = path.join(__dirname, 'dist');

app.use(express.static(distPath));

// هر آدرس دیگری -> index.html (برای React Router)
app.get('*', (req, res) => {
  res.sendFile(path.join(distPath, 'index.html'));
});

// ---------- استارت سرور ----------
app.listen(PORT, '0.0.0() => {
  console.log(`Server listening on port ${PORT}`);
});
